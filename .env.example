# Zipd / LinkSnip — copy to .env.local and fill in

# Neon API (optional — for CLI/scripts; never commit real key)
NEON_API_KEY=napi_...
NEON_ORG_ID=org-...
NEON_PROJECT_ID=...

# Neon Postgres (required for short links + analytics)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
# Prefer non-pooling for Edge if available:
# DATABASE_URL_UNPOOLED=
# POSTGRES_URL_NON_POOLING=

# Clerk auth (required for dashboard) — see docs/CLERK_SETUP.md
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
# Comma-separated Clerk user IDs allowed as vault admins
AUTHORIZED_USER_IDS=user_...

# Edge short-link resolve (set a long random secret in production)
EDGE_INTERNAL_SECRET=
ACCESS_MASTER_TOKEN=

# WebAuthn / security (optional overrides)
SECURITY_VAULT_SECRET=
