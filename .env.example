# Zipd / LinkSnip — copy to .env.local and fill in

# Neon Postgres (required for short links + analytics)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
# Prefer non-pooling for Edge if available:
# DATABASE_URL_UNPOOLED=
# POSTGRES_URL_NON_POOLING=

# Clerk auth (required for dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Comma-separated Clerk user IDs allowed into the vault
AUTHORIZED_USER_IDS=user_...

# Edge short-link resolve (set a long random secret in production)
EDGE_INTERNAL_SECRET=
ACCESS_MASTER_TOKEN=

# WebAuthn / security (optional overrides)
SECURITY_VAULT_SECRET=
